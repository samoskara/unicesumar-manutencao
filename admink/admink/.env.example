# Exemplo de arquivo de ambiente para o Admink
# Copie este arquivo para `.env` e depois preencha apenas os campos que faltam.

APP_NAME=Admink
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=admink
DB_USERNAME=admink_app
DB_PASSWORD=sua_senha_do_banco_aqui

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# E-mail: deixe os campos abaixo como estão se ainda não for usar envio de e-mails.
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Google Calendar: keep disabled until OAuth credentials are configured.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_TIMEOUT=10

# Local demo login: keep disabled outside local screenshots.
LOCAL_LOGIN_ENABLED=false
LOCAL_LOGIN_EMAIL=admin@local.test
LOCAL_LOGIN_PASSWORD=admin123
LOCAL_LOGIN_NAME="Admin Local"
LOCAL_LOGIN_ESTUDIO_ID=1
LOCAL_LOGIN_ESTUDIO_NOME="Estudio Local"
